# Required for the prompt and OCR agents to call upstream APIs.
GEMINI_API_KEY=your-gemini-api-key-here
# Optional — only if you want to use Anthropic-routed prompts.
ANTHROPIC_API_KEY=

# Per-prompt model overrides take precedence over this env default.
# Used by the OCR agent and as fallback for prompts that don't pin a model.
LAMBE_MODEL=gemini-2.5-flash

# Optional — where the daemon stores per-project data (slices, extractions,
# prompt outputs, SQLite DB). Defaults to a platform-specific user data dir.
# CHARGESHEET_DATA_DIR=/path/to/data

# Optional — override where the daemon looks for the agents/ directory.
# Default resolution: $LAMBE_AGENTS_DIR -> <binary_dir>/../agents ->
# <binary_dir>/../../agents -> ./agents. Set this if you're running the
# binary from an unusual location.
# LAMBE_AGENTS_DIR=/path/to/lambe-haath/agents

# Optional — Gemini context cache TTL in seconds. Default 3600. Min 60, max 86400.
# LAMBE_CACHE_TTL_SECONDS=3600
